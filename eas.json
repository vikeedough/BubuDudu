{
    "cli": {
        "version": ">= 14.2.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": { "APP_VARIANT": "dev" }
        },
        "preview": {
            "distribution": "internal",
            "android": { "buildType": "apk" },
            "env": { "APP_VARIANT": "prod" }
        },
        "production": {
            "autoIncrement": true,
            "env": { "APP_VARIANT": "prod" }
        }
    },
    "submit": {
        "production": {}
    }
}
